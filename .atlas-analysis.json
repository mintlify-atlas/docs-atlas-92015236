{
  "projectType": "saas",
  "projectName": "Ophira Web",
  "projectDescription": "A fixed asset management web platform for tracking inventory, auditing assets by location, scanning QR codes, and generating reports.",
  "theme": "luma",
  "primaryColor": "#2563eb",
  "lightColor": "#eff6ff",
  "darkColor": "#1e3a8a",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/dashboard",
              "features/assets",
              "features/scanner",
              "features/audits",
              "features/history"
            ]
          },
          {
            "group": "Administration",
            "pages": [
              "admin/users",
              "admin/locations",
              "admin/categories"
            ]
          },
          {
            "group": "Reports & Exports",
            "pages": [
              "reports/overview",
              "reports/exporting"
            ]
          }
        ]
      },
      {
        "tab": "Developer Guide",
        "groups": [
          {
            "group": "Architecture",
            "pages": [
              "dev/architecture",
              "dev/api-client",
              "dev/routing"
            ]
          },
          {
            "group": "Setup & Deployment",
            "pages": [
              "dev/setup",
